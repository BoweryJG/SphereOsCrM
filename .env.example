# Main CRM Database (Supabase)
REACT_APP_SUPABASE_URL=your_crm_supabase_url
REACT_APP_SUPABASE_ANON_KEY=your_crm_supabase_anon_key

# Market Data Database (Supabase - separate project)
REACT_APP_MARKET_DATA_SUPABASE_URL=your_market_data_supabase_url
REACT_APP_MARKET_DATA_SUPABASE_ANON_KEY=your_market_data_supabase_anon_key

# Twilio Configuration
REACT_APP_TWILIO_ACCOUNT_SID=your_twilio_account_sid
REACT_APP_TWILIO_AUTH_TOKEN=your_twilio_auth_token
REACT_APP_TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Stripe Configuration
REACT_APP_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Application Settings
REACT_APP_ENABLE_MOCK_DATA=true